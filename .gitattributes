# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python

# Markdown
*.md text diff=markdown

# YAML
*.yml text
*.yaml text

# JSON
*.json text

# TOML
*.toml text

# Shell scripts
*.sh text eol=lf

# Binary files
*.mp4 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
