# -----------------------------------------------------------------------------
# AD GENERATION PIPELINE - ENVIRONMENT CONFIGURATION
# -----------------------------------------------------------------------------

# Google GenAI API Key (Required for gemini models)
GEMINI_API_KEY=your_api_key_here

# Default specific models (Optional tuning)
DEFAULT_TEXT_MODEL=gemini-3.1-pro-preview
DEFAULT_EVALUATION_MODEL=gemini-3.1-flash-lite-preview
DEFAULT_VIDEO_MODEL=veo-3.1-generate-preview

# Logging
LOG_LEVEL=INFO
